<Window x:Class="SimTools.ExclusiveItems"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SimTools"
        mc:Ignorable="d"
        Title="SimTools — Exclusive Items"
        Height="640" Width="840"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Menu_Main.png"/>
        </Grid.Background>

        <!-- Close button -->
        <Button x:Name="ExitApp" Content="" HorizontalAlignment="Left"
                Margin="801,8,0,0" VerticalAlignment="Top"
                Click="ExitApp_Click" Width="32" Height="32"
                BorderBrush="{x:Null}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/close-button.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/close-hover.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Title -->
        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="16,16,0,0"
                   Text="Exclusive Items"
                   Foreground="#FFD700"
                   FontFamily="Tahoma"
                   FontWeight="Bold"
                   FontSize="20"/>

        <!-- Content area -->
        <ScrollViewer HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="16,56,0,0" Width="808" Height="564"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="ExclusiveItemsText"
                           TextWrapping="Wrap"
                           Foreground="#FF13FF00"
                           FontFamily="Tahoma"
                           FontSize="12"
                           Margin="0,0,0,12"
                           Text="Exclusive donor content will appear here."/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>

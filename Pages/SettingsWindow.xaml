<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="av"
        x:Class="SimTools.SettingsWindow"
        Title="SimTools - Settings"
        Width="680" Height="720"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="DarkTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background"               Value="#F5F5F5"/>
            <Setter Property="Foreground"               Value="#1A1A1A"/>
            <Setter Property="BorderBrush"              Value="#CCCCCC"/>
            <Setter Property="FontFamily"               Value="Tahoma"/>
            <Setter Property="FontSize"                 Value="11"/>
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="Padding"                  Value="4 0 4 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="{x:Type Button}">
            <Setter Property="Background"  Value="#E0E0E0"/>
            <Setter Property="Foreground"  Value="#1A1A1A"/>
            <Setter Property="FontFamily"  Value="Tahoma"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Height"      Value="30"/>
            <Setter Property="Padding"     Value="10 0 10 0"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Width"   Value="70"/>
            <Setter Property="Height"  Value="26"/>
            <Setter Property="Margin"  Value="4 0 0 0"/>
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"  Value="#FFD200"/>
            <Setter Property="FontFamily"  Value="Tahoma"/>
            <Setter Property="FontSize"    Value="15"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0 12 0 8"/>
        </Style>

        <Style x:Key="RowLabelText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"        Value="#AAAAAA"/>
            <Setter Property="FontFamily"        Value="Tahoma"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Width"             Value="110"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GameNameText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontFamily"  Value="Tahoma"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0 6 0 3"/>
        </Style>

        <Style x:Key="DividerLine" TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="#373737"/>
            <Setter Property="Margin"     Value="0 8 0 8"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <ImageBrush ImageSource="/Images/TS3_Box.png"/>
    </Window.Background>

    <!-- ── Root: fixed frame sized to the background image ── -->
    <Grid x:Name="SettingsPanel"
          Width="638" Height="564"
          Margin="0,-87,0,-13"
          Background="#7F4A89A4">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- scrollable content -->
            <RowDefinition Height="64"/>
            <!-- buttons, always fixed at bottom -->
        </Grid.RowDefinitions>

        <!-- ── Scrollable content ── -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16">
            <StackPanel>

                <!-- ── Language ─────────────────────────────────────── -->
                <TextBlock x:Name="SectionLangHeader"
                           Style="{StaticResource SectionHeaderText}"
                           Text="Languages"/>

                <DockPanel Margin="0 0 0 6">
                    <TextBlock Style="{StaticResource RowLabelText}"
                               Text="Change Language:"
                               Foreground="White"/>
                    <ComboBox x:Name="LangCombo"
                              Width="160" Margin="8 0 0 0"
                              VerticalAlignment="Center"/>
                </DockPanel>

                <Button x:Name="ResetLangBtn"
                        Style="{StaticResource DarkButton}"
                        HorizontalAlignment="Left"
                        Width="Auto" MinWidth="200"
                        Margin="0 6 0 20"
                        Content="Reset - Show Language Selection on Next Launch"
                        Background="White" Foreground="#FF373737"
                        Click="ResetLanguage_Click"/>

                <!-- ── Network ───────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SectionHeaderText}"
                           Text="SimTools Repo Location"/>

                <Grid Margin="0 0 0 4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource RowLabelText}"
                               Text="Repo URL:"
                               Foreground="White"/>
                    <TextBox x:Name="BaseUrlBox"
                             Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Background="White" Foreground="#FF373737"/>
                </Grid>

                <Button x:Name="ResetUrlBtn"
                        Style="{StaticResource DarkButton}"
                        HorizontalAlignment="Left"
                        Width="Auto" MinWidth="200"
                        Margin="0 4 0 20"
                        Background="White" Foreground="#FF373737"
                        Click="ResetUrl_Click"/>

                <!-- ── Music ─────────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SectionHeaderText}"
                           Text="Music Player"/>

                <CheckBox x:Name="MusicEnabledCheck"
                          Content="Enable music player"
                          Foreground="#DCDCDC"
                          FontSize="13"
                          Margin="0 0 0 4"
                          IsChecked="True"/>

                <TextBlock Foreground="White"
                           FontFamily="Tahoma" FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0 0 0 20"
                           Text="Place your own songs (MP3 / WAV / FLAC / M4A) in the /Resources/Music folder."/>

                <!-- ── Updates ───────────────────────────────────────── -->
                <TextBlock Style="{StaticResource SectionHeaderText}"
                           Text="Updates"/>

                <TextBlock Foreground="#DCDCDC"
                           FontFamily="Tahoma" FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0 0 0 8"
                           Text="If you previously suppressed automatic update notifications (either for 30 days or indefinitely), use the button below to re-enable them."/>

                <Button x:Name="ResetAutoUpdateBtn"
                        Style="{StaticResource DarkButton}"
                        HorizontalAlignment="Left"
                        Width="Auto" MinWidth="220"
                        Margin="0 0 0 20"
                        Content="Reset Auto-Update Check"
                        Background="White" Foreground="#FF373737"
                        Click="ResetAutoUpdateCheck_Click"/>

                <!-- ── Game &amp; Mod Directories ────────────────────── -->
                <TextBlock x:Name="SectionDirsHeader"
                           Style="{StaticResource SectionHeaderText}"
                           Text="Game &amp; Mod Directories"/>

                <!-- ── Auto-Detect row ──────────────────────────────────── -->
                <Grid Margin="0 6 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource RowLabelText}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top"
                               Text="SimTools will attempt to locate your game and mod directories automatically. Only empty fields are filled — existing paths are never overwritten." HorizontalAlignment="Left" Width="450"/>
                    <Button x:Name="AutoDetectBtn"
                            Grid.Column="1"
                            Style="{StaticResource DarkButton}"
                            Content="Auto-Detect All"
                            MinWidth="120"
                            Margin="12 0 0 0"
                            Background="White" Foreground="#FF373737"
                            Click="AutoDetect_Click"/>
                </Grid>

                <ItemsControl x:Name="GameDirsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource GameNameText}"/>

                                <Grid Margin="0 2 0 2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                               Style="{StaticResource RowLabelText}"
                               Text="Game Directory:"/>
                                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding GameDir, UpdateSourceTrigger=PropertyChanged}"
                             Margin="4 0"/>
                                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseButton}"
                            Content="Browse..."
                            Command="{Binding BrowseGameCommand}"/>
                                </Grid>

                                <Grid Margin="0 2 0 2"
                      Visibility="{Binding HasMods, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                               Style="{StaticResource RowLabelText}"
                               Text="Mods Directory:"/>
                                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding ModDir, UpdateSourceTrigger=PropertyChanged}"
                             Margin="4 0"/>
                                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseButton}"
                            Content="Browse..."
                            Command="{Binding BrowseModCommand}"/>
                                </Grid>

                                <Grid Margin="0 2 0 2"
                      Visibility="{Binding HasUserData, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                               Style="{StaticResource RowLabelText}"
                               Text="User Data:"/>
                                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding UserDataDir, UpdateSourceTrigger=PropertyChanged}"
                             Margin="4 0"/>
                                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseButton}"
                            Content="Browse..."
                            Command="{Binding BrowseUserDataCommand}"/>
                                </Grid>

                                <Separator Style="{StaticResource DividerLine}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Save / Cancel — fixed at bottom, never scrolls ── -->
        <Canvas x:Name="SaveCnclButtonCanvas" Grid.Row="1" Margin="561,94,-14,-105">
            <Button x:Name="CancelBtn"
                    Style="{StaticResource DarkButton}"
                    Width="30" Height="44"
                    Content="Cancel" Canvas.Top="16"
                    Click="Cancel_Click"
                    Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}"
                    HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="3" Opacity="0"/>
            <Button x:Name="SaveBtn"
                    Style="{StaticResource DarkButton}"
                    Width="49" Height="66"
                    Content="Save"
                    Canvas.Left="42" Canvas.Top="4"
                    Click="Save_Click"
                    Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0"/>
        </Canvas>

    </Grid>

</Window>

<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimTools"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:Mime="clr-namespace:System.Net.Mime;assembly=System.Net.Mail"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms" x:Name="MainPage"
        x:Class="SimTools.MainWindow"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="SimTools - Main Page" Height="640" Width="840" WindowStyle="None" Icon="/SimTools.ico" ResizeMode="NoResize">
    <Grid x:Name="RootGrid" Width="840" Height="640">
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Menu_Main.png"/>
        </Grid.Background>
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob.gif" HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Stretch="Fill"/>
        <!-- <Image HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Source="/plumbob.gif" Stretch="Fill"/> -->
        <Image x:Name="SimTools_Logo" HorizontalAlignment="Left" Height="200" Margin="8,6,0,0" VerticalAlignment="Top" Width="162" Source="/Images/SimTools_Logo.png" Stretch="Fill"/>
        <!-- Settings button — top-right corner -->
        <Button x:Name="ExitApp" Content="Button" HorizontalAlignment="Right" Margin="0,8,18,0" VerticalAlignment="Top" BorderBrush="{x:Null}" Foreground="{x:Null}" Width="32" Height="32" Click="ExitApp_Click">
            <Button.Background>
                <ImageBrush ImageSource="/Images/close-button.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="GenericKeysButton" Content="Back to Main Menu" HorizontalAlignment="Left" Margin="8,596,0,0" VerticalAlignment="Top" Width="159" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TweakButton_Click" FontSize="11" ContextMenuOpening="TweakButton_Context" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
        <RichTextBox Margin="541,787,63,-255">
            <FlowDocument>
                <Paragraph>
                    <Run Text="RichTextBox"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <RichTextBox Width="160" Height="33" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,600,0,0" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="White" SelectionBrush="{x:Null}" SelectionTextBrush="{x:Null}" FontFamily="SimSun" FontSize="11" FontWeight="Bold">
            <FlowDocument/>
        </RichTextBox>
        <ListBox x:Name="BuyGamesDigital" d:ItemsSource="{d:SampleData ItemCount=5}" Width="296" Height="265" Margin="184,288,0,-3" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <ListBox x:Name="BuyGamesRetail" d:ItemsSource="{d:SampleData ItemCount=5}" Width="296" Height="265" Margin="496,288,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBlock x:Name="UseText" HorizontalAlignment="Left" Margin="184,8,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="601" Height="65" FontFamily="SimSun" Foreground="White" FontSize="11"><Run Text="You can use the following selection box to select the game(s) you would like to purchase, and it will redirect you to that games purchase page with your given selections. The sections are expandable."/><LineBreak/><Run/><LineBreak/><Run Text="All links are affiliated and tied to TS3Tools, I will earn 2% - 5% of each sale if you decide to purchase through any of my links here in TS3Tools. Doing so supports future development of TS3Tools."/></TextBlock>
    </Grid>
</Window>

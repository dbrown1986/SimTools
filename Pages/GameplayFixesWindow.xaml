<Window x:Class="SimTools.GameplayFixesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimTools"
        Title="Gameplay Fixes AIO &#x2014; The Sims 3"
        Width="720" Height="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>

        <!-- ── Section "Select All" checkbox style ── -->
        <Style x:Key="SectionCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#B4B4B4"/>
            <Setter Property="FontStyle"  Value="Italic"/>
            <Setter Property="Margin"     Value="0 0 0 5"/>
        </Style>

        <!-- ── Expander header text ── -->
        <Style x:Key="ExpanderHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FFD200"/>
            <Setter Property="FontFamily"        Value="Tahoma"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── Expander toggle button ──
             Two chevron Paths swap Visibility to avoid RotateTransform
             TargetName limitations in ControlTemplate triggers.        ── -->
        <Style x:Key="ExpanderToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Focusable"   Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="2">
                            <Grid Width="14" Height="14">
                                <!-- Expanded state: chevron pointing down ▾ -->
                                <Path x:Name="ChevronDown"
                                      Data="M 1 3 L 7 9 L 13 3"
                                      Stroke="#FFD200"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Visible"/>
                                <!-- Collapsed state: chevron pointing right ▶ -->
                                <Path x:Name="ChevronRight"
                                      Data="M 3 1 L 9 7 L 3 13"
                                      Stroke="#FFD200"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- IsChecked=False means the Expander is collapsed -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="ChevronDown"  Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ChevronRight" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Full Expander style ── -->
        <Style TargetType="Expander">
            <Setter Property="Background"      Value="#222222"/>
            <Setter Property="BorderBrush"     Value="#464646"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="4 4 4 4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <DockPanel>

                                <!-- Header row -->
                                <Border DockPanel.Dock="Top"
                                        Background="#2A2A2A"
                                        CornerRadius="3 3 0 0"
                                        Padding="8 6">
                                    <DockPanel>
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Style="{StaticResource ExpanderToggleButton}"
                                                      IsChecked="{Binding IsExpanded,
                                                                  RelativeSource={RelativeSource TemplatedParent},
                                                                  Mode=TwoWay}"
                                                      Width="20" Height="20"
                                                      Margin="4 0 0 0"/>
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- Collapsible content -->
                                <ContentPresenter x:Name="ExpandSite"
                                                  DockPanel.Dock="Bottom"
                                                  Visibility="Collapsed"
                                                  Margin="8 6 8 8"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark scrollbar thumb ── -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#666666"
                                CornerRadius="3"
                                Margin="2 0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Background" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark vertical ScrollBar ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"    Value="14"/>
            <Setter Property="MinWidth" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"/>
                                <RowDefinition/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="3"
                                    Background="#2A2A2A"
                                    CornerRadius="2"/>

                            <!-- Up arrow -->
                            <RepeatButton Grid.Row="0"
                                          Command="ScrollBar.LineUpCommand"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False">
                                <Path Data="M 6 2 L 12 10 L 0 10 Z"
                                      Fill="#AAAAAA"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </RepeatButton>

                            <!-- Thumb track -->
                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>

                            <!-- Down arrow -->
                            <RepeatButton Grid.Row="2"
                                          Command="ScrollBar.LineDownCommand"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False">
                                <Path Data="M 6 10 L 12 2 L 0 2 Z"
                                      Fill="#AAAAAA"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Window.Background>
        <ImageBrush/>
    </Window.Background>

    <DockPanel>

        <!-- ── Bottom button bar ── -->
        <Grid DockPanel.Dock="Bottom"
              Margin="12 8 12 12"
              Height="40">
            <Button Content="Cancel"
                    Width="100" Height="30"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#373737" Foreground="White"
                    FontFamily="Tahoma" FontWeight="Bold"
                    Click="Cancel_Click"/>
            <Button x:Name="DownloadBtn"
                    Content="Download Selected"
                    Width="160" Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#FFD200" Foreground="Black"
                    FontFamily="Tahoma" FontWeight="Bold"
                    Click="DownloadSelected_Click"/>
        </Grid>

        <!-- ── Global "Select All" ── -->
        <CheckBox x:Name="GlobalSelectAll"
                  DockPanel.Dock="Top"
                  Content="Select All"
                  Foreground="White"
                  FontWeight="Bold"
                  FontFamily="Tahoma"
                  Margin="12 10 12 4"
                  Click="GlobalSelectAll_Click"/>

        <!-- ── Scrollable sections ── -->
        <ScrollViewer VerticalScrollBarVisibility="Visible"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8 4 8 4">

            <ItemsControl x:Name="SectionsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:GameplaySectionViewModel}">

                        <Expander IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="{Binding Header}"
                                           Style="{StaticResource ExpanderHeaderText}"/>
                            </Expander.Header>

                            <StackPanel>
                                <!-- Per-section "Select All" -->
                                <CheckBox Style="{StaticResource SectionCheckBox}"
                                          Content="Select All"
                                          IsThreeState="True"
                                          IsChecked="{Binding IsAllSelected, Mode=OneWay}"
                                          Command="{Binding ToggleAllCommand}"/>

                                <!-- Fix items -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:GameplayFixViewModel}">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsActive}"
                                                      Content="{Binding DisplayName}"
                                                      Margin="0 2">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox">
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Foreground" Value="#4B4B4B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </Expander>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>
    </DockPanel>
</Window>

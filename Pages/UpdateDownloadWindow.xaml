<Window x:Class="SimTools.UpdateDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#1E1E1E"
            CornerRadius="8"
            Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                              Color="Black" Opacity="0.7"/>
        </Border.Effect>

        <StackPanel>

            <!-- Title -->
            <TextBlock Text="Downloading Update"
                       Foreground="White"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBlock x:Name="FileNameLabel"
                       Text=""
                       Foreground="#888888"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,20"/>

            <!-- Status -->
            <TextBlock x:Name="StatusLabel"
                       Text="Connecting…"
                       Foreground="#CCCCCC"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,8"/>

            <!-- Progress bar -->
            <ProgressBar x:Name="DownloadProgressBar"
                         Height="10"
                         Minimum="0" Maximum="1" Value="0"
                         Background="#2D2D2D"
                         Foreground="#4A7EBE"
                         BorderThickness="0"
                         Margin="0,0,0,6"/>

            <!-- Byte count -->
            <TextBlock x:Name="BytesLabel"
                       Text=""
                       Foreground="#888888"
                       FontSize="10"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,24"/>

            <!-- Cancel button -->
            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Width="110" Height="34"
                    HorizontalAlignment="Center"
                    Background="#3A3A3A"
                    Foreground="White"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    FontSize="12"
                    Cursor="Hand"
                    Click="Cancel_Click"/>

        </StackPanel>
    </Border>
</Window>

<Window x:Class="SimTools.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="SimTools"
        Height="320" Width="480"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Opacity="0" Background="{x:Null}" Foreground="{x:Null}">

    <Grid Width="480" Height="320">
        <!-- Background image fills the window -->

        <!-- Animated plumbob top-left, matching MainWindow -->
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob.gif"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Width="113" Height="201" Stretch="Fill"
               Margin="184,40,0,0"/>

        <!-- Logo -->
        <Image Source="/Images/SimTools_Logo.png"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Width="162" Height="202" Stretch="Uniform"
               Margin="160,40,0,0"/>

        <!-- App name centred -->
        <TextBlock x:Name="Retic"
		   Text="Reticulating Splines..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontFamily="Tahoma" FontSize="32" FontWeight="Bold"
                   Foreground="#FFFFD200" Margin="8,272,0,0" FontStyle="Italic"/>

        <!-- Loading label bottom-centre -->
        <TextBlock x:Name="LoadingText"
				   Text="Loading..."
				   HorizontalAlignment="Left"
				   VerticalAlignment="Top"
				   FontFamily="Tahoma"
				   Foreground="White" Margin="376,248,0,0" Width="80" Height="17" FontWeight="Bold"/>
    </Grid>
</Window>
<Window x:Class="SimTools.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="SimTools"
        Height="320" Width="480"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Opacity="0" Background="{x:Null}" Foreground="{x:Null}">

    <Grid Width="480" Height="320">
        <!-- Background image fills the window -->
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob_shatter.gif" Stretch="Fill"/>

        <!-- Logo -->

        <!-- App name centred -->
        <TextBlock x:Name="Retic"
		   Text="Reticulating Splines..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontFamily="Tahoma" FontSize="32" FontWeight="Bold"
                   Foreground="#FFFFD200" Margin="8,272,0,0" FontStyle="Italic"/>

        <!-- Loading label bottom-centre -->
        <TextBlock x:Name="LoadingText"
				   Text="Loading..."
				   HorizontalAlignment="Left"
				   VerticalAlignment="Top"
				   FontFamily="Tahoma"
				   Foreground="White" Margin="376,248,0,0" Width="80" Height="17" FontWeight="Bold"/>
    </Grid>
</Window>
<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimTools_v4"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:Mime="clr-namespace:System.Net.Mime;assembly=System.Net.Mail"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms" x:Name="MainPage"
        x:Class="SimTools_v4.MainWindow"
        mc:Ignorable="d"
        Title="SimTools - Main Page" Height="720" Width="840" WindowStyle="None" Icon="/SimTools.ico" ResizeMode="NoResize">
    <Grid x:Name="RootGrid" Width="840">
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Menu_Main.png"/>
        </Grid.Background>
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob.gif" HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Stretch="Fill"/>
        <!-- <Image HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Source="/plumbob.gif" Stretch="Fill"/> -->
        <Image x:Name="SimTools_Logo" HorizontalAlignment="Left" Height="200" Margin="8,6,0,0" VerticalAlignment="Top" Width="162" Source="/Images/SimTools_Logo.png" Stretch="Fill"/>
        <TextBlock x:Name="ButtonInfoText" HorizontalAlignment="Left" Margin="184,24,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="433" Height="91" FontFamily="Tahoma" FontWeight="Bold" Foreground="#FFFFD200"><Run Text="When selecting an option, each button will change colors when your mouse is over it. These colors will indicate the importance of each function. Green is normal, yellow is recommended, red is highly recommended. As a rule of thumb, almost all tweaks and bugfixes will probably require the mod framework to be installed."/><LineBreak/><Run/></TextBlock>
        <TextBlock x:Name="FrameworkInfoText" HorizontalAlignment="Left" Margin="184,121,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="433" Height="87" FontFamily="Tahoma" FontWeight="Bold" Foreground="Red" Text="It is strongly recommended to install the Mod Framework. If you already have the Mod Framework, please purge your 'Mods' folder and reinstall from the buton below. This version of the Mod Framework is specially vetted and prepared for TS3Tools."/>
        <TextBlock x:Name="ComparisonText" HorizontalAlignment="Left" Margin="624,24,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="153" Height="25" FontFamily="SimSun" Foreground="White" FontWeight="Bold" FontStyle="Italic" FontSize="22" TextDecorations="Underline" TextAlignment="Center"><Run Text="Comparison"/><LineBreak/><Run/></TextBlock>
        <!-- Settings button — top-right corner -->
        <Button x:Name="SettingsButton"
        Content="⚙"
        HorizontalAlignment="Right" VerticalAlignment="Top"
        Margin="0,45,18,0"
        Width="32" Height="32"
        FontSize="16"
        ToolTip="Settings"
        Click="SettingsButton_Click" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_yellow.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="TS3Vanilla" Content="TS3 Vanilla (No Mods)" HorizontalAlignment="Left" Margin="624,56,0,0" VerticalAlignment="Top" Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TS3Vanilla_Click" FontSize="11" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="TS3WithSimTools" Content="TS3 With SimTools" HorizontalAlignment="Left" Margin="624,95,0,0" VerticalAlignment="Top" Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="WithSimTools_Click" FontSize="11" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="VideoTutorial" Content="SimTools Video Guide" HorizontalAlignment="Left" Margin="624,168,0,0" VerticalAlignment="Top" Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="VideoTutorial_Click" FontSize="11" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="NewGPUButton" Content="GPU Support &gt;"
        HorizontalAlignment="Left" Margin="8,210,0,0" VerticalAlignment="Top"
        Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold"
        Click="NewGPUButton_Click" FontSize="11"
        ContextMenuOpening="NewGPUButton_Context" BorderBrush="{x:Null}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_red.png"/>
                                </Setter.Value>
                            </Setter>
							<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}">
								<ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Setter.Value>
</Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <Button x:Name="TweakButton" Content="Game Tweaks &gt;" HorizontalAlignment="Left" Margin="8,249,0,0" VerticalAlignment="Top" Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TweakButton_Click" FontSize="11" ContextMenuOpening="TweakButton_Context" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
        <TextBlock x:Name="GPUText" HorizontalAlignment="Left" Margin="184,208,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="401" Height="36" FontFamily="SimSun" Foreground="White" Text="Use these tools to identify and install support for your GPU to help leverage the games engine. Available for Sims 2, Sims Stories and Sims 3." FontSize="11"/>
        <TextBlock x:Name="TweakText" HorizontalAlignment="Left" Margin="184,249,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="401" Height="36" FontFamily="SimSun" Foreground="White" Text="This menu features loads of tweaks, all of which will help games run better in many different ways. Only select fixes for expansions you have installed." FontSize="11"/>
        <Button x:Name="ExitApp" Content="Button" HorizontalAlignment="Right" Margin="0,8,18,0" VerticalAlignment="Top" BorderBrush="{x:Null}" Foreground="{x:Null}" Width="32" Height="32" Click="ExitApp_Click">
            <Button.Background>
                <ImageBrush ImageSource="/Images/close-button.png"/>
            </Button.Background>
        </Button>
    </Grid>
</Window>

<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimTools_v4"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:Mime="clr-namespace:System.Net.Mime;assembly=System.Net.Mail"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms" x:Name="MainPage"
        x:Class="SimTools_v4.MainWindow"
        mc:Ignorable="d"
        Title="SimTools - Main Page" Height="720" Width="840" WindowStyle="None" Icon="/SimTools.ico" ResizeMode="NoResize">
    <Grid x:Name="RootGrid" Width="840">
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Menu_Main.png"/>
        </Grid.Background>
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob.gif" HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Stretch="Fill"/>
        <!-- <Image HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Source="/plumbob.gif" Stretch="Fill"/> -->
        <Image x:Name="SimTools_Logo" HorizontalAlignment="Left" Height="200" Margin="8,6,0,0" VerticalAlignment="Top" Width="162" Source="/Images/SimTools_Logo.png" Stretch="Fill"/>
        <!-- Settings button — top-right corner -->
        <Button x:Name="UpdateButton" Content="Check for Updates" HorizontalAlignment="Left" Margin="8,218,0,0" VerticalAlignment="Top" Width="154" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TweakButton_Click" FontSize="11" ContextMenuOpening="TweakButton_Context" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_yellow.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="ExitApp" Content="Button" HorizontalAlignment="Right" Margin="0,8,18,0" VerticalAlignment="Top" BorderBrush="{x:Null}" Foreground="{x:Null}" Width="32" Height="32" Click="ExitApp_Click">
            <Button.Background>
                <ImageBrush ImageSource="/Images/close-button.png"/>
            </Button.Background>
        </Button>
        <TextBlock x:Name="IntroText1" HorizontalAlignment="Left" Margin="192,16,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Background="#3FFFFFFF" Foreground="#FF42FF00" FontFamily="Tahoma" FontWeight="Bold" Width="353" Height="609"><Run Text="Welcome to the SimTools Suite"/><LineBreak/><Run/><LineBreak/><Run Text="This program will help guide you through installing and implementing the best tweaks for your installation of the various sim games. Many of the older games are left unoptimized and even more so, early Maxis games circa 1990's have a hard time running on newer hardware."/><LineBreak/><Run/><LineBreak/><Run Text="This suite of tools will allow personal computers, either old or new to run the games at a much better pace by enabling certain features left disabled at release, patching old executables, disabling unecessary features (such as certain hard drive caching methods when most modern PC's have solid state drives now) and much more! A great deal of care has gone into this tool."/><LineBreak/><Run/><LineBreak/><Run Text="It is HIGHLY recommended that you run this tool on a FRESH install of your sim games. Please be sure you create a backup of your games installation in case you run into any issues while installing the fixes and tweaks that are provided with this tool."/><LineBreak/><Run/><LineBreak/><Run Text="Some input by the end-user (you) is required. This program will attempt to break everything down as best as possible, and even automate some features, but if ever you find you are uncertain what a feature does, you can cancel it and are encouraged to do so to avoid breaking your games installation."/><LineBreak/><Run/><LineBreak/><Run Text="When you're finished reading this message, please click the continue button below on the bottom left; to continue, or click the red 'X' above to the upper right to exit this program."/><LineBreak/><Run/><LineBreak/><Run Text="P.S. - There is an easter egg within the program. It is only on ONE sub-page and hidden deep. Props to anyone who can find it. If you do, feel free to comment on the Discord about it."/><LineBreak/><Run/></TextBlock>
        <Image x:Name="SulSul" HorizontalAlignment="Left" Height="273" Margin="560,168,0,0" VerticalAlignment="Top" Width="273" Source="/Images/sulsul.png"/>
        <Button x:Name="SimToolsButton" Content="What is Simtools?" HorizontalAlignment="Left" Margin="616,448,0,0" VerticalAlignment="Top" Width="162" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TweakButton_Click" FontSize="11" ContextMenuOpening="TweakButton_Context" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_red.png"/>
            </Button.Background>
        </Button>
        <Button x:Name="UpdateButton_Copy1" Content="Continue" HorizontalAlignment="Left" Margin="8,600,0,0" VerticalAlignment="Top" Width="162" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="TweakButton_Click" FontSize="11" ContextMenuOpening="TweakButton_Context" BorderBrush="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/Images/button_normal.png"/>
            </Button.Background>
        </Button>
    </Grid>
</Window>

    <Window x:Class="SimTools.MusicPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="256"
        SizeToContent="Height"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Shared style for all four control buttons -->
        <Style x:Key="PlayerBtn" TargetType="Button">
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="#2D2D2D"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="2"/>
        </Style>
    </Window.Resources>

    <!-- Outer container: dark card with rounded corners and drop shadow -->
    <Border
            CornerRadius="8"
            Padding="10">
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF0C3C0B"/>
                <GradientStop Color="#19159A11" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="3"
                              Color="Black" Opacity="0.65"/>
        </Border.Effect>

        <StackPanel>

            <!-- ═══ Album art  +  Song info ════════════════════════════════ -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Album art box -->
                <Border Grid.Column="0"
                        Width="76" Height="76"
                        CornerRadius="4"
                        Background="#2D2D2D"
                        Margin="0,0,10,0"
                        ClipToBounds="True">
                    <Grid>
                        <!-- Placeholder shown when no embedded art is found -->
                        <TextBlock x:Name="ArtPlaceholder"
                                   Text="♪" FontSize="28"
                                   Foreground="#AAAAAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <!-- Populated from ID3 tag data at runtime -->
                        <Image x:Name="AlbumArtImage"
                               Stretch="UniformToFill"
                               Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Title / artist / time -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleBlock"
                               Text="No track loaded"
                               Foreground="White"
                               FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"/>
                    <TextBlock x:Name="ArtistBlock"
                               Text=""
                               Foreground="#AAAAAA"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="TimeBlock"
                               Text="0:00 / 0:00"
                               Foreground="#AAAAAA"
                               FontSize="10"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ═══ Control buttons ═════════════════════════════════════════ -->
            <!-- Order: ⏮  ▶/⏸  ⏭  ■  🔊  ♪ -->
            <UniformGrid Rows="1" Margin="0,2,0,0">
                <Button Content="⏮" Click="SkipBack_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_green.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_red.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="PlayPauseBtn" Content="▶" Click="PlayPause_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_green.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_red.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="⏭" Click="SkipForward_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_green.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_red.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="■" Click="Stop_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_red.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_gray.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="MuteBtn" Content="🔊" Click="Mute_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_gray.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_red.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
                <!-- ♪ button opens the song-selection popup -->
                <Button Content="♪" Click="Note_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PlayerBtn}">

                            <!-- Default background image -->
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_normal.png"
                                Stretch="Fill"/>
                                </Setter.Value>
                            </Setter>

                            <!-- Base template — must be here so Background renders at all -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_yellow.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <ImageBrush ImageSource="/Images/button_red.png"
                                        Stretch="Fill"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>

                        </Style>
                    </Button.Style>
                </Button>
            </UniformGrid>

            <!-- ═══ Song-selection popup (toggled by the ♪ button) ══════════ -->
            <Popup x:Name="SongPopup"
                   PlacementTarget="{Binding ElementName=NoteBtn}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="#1E1E1E"
                        BorderBrush="#4A9E5C"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="2">
                    <ListBox x:Name="SongList"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderBrush="#3A3A3A"
                             MaxHeight="280" MinWidth="234"
                             FontSize="11"
                             MouseDoubleClick="SongList_DoubleClick"/>
                </Border>
            </Popup>

        </StackPanel>
    </Border>
</Window>

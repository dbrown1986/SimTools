<Window x:Class="SimTools.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Downloading"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False" WindowStyle="None" Height="170" AllowsTransparency="True">
    <Window.Background>
        <ImageBrush ImageSource="/Images/TS3_Box3.png"/>
    </Window.Background>

    <Grid Margin="16 12 16 14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText"
                   Grid.Row="0"
                   Text="Preparing&#x2026;"
                   TextWrapping="Wrap"
                   Foreground="White"
                   FontFamily="Tahoma"
                   FontSize="16" HorizontalAlignment="Center" Margin="0,40,0,57" Grid.RowSpan="3"/>

        <ProgressBar x:Name="ProgressBar"
                     Grid.Row="2"
                     Height="36"
                     Minimum="0" Maximum="100" Value="0" BorderBrush="{x:Null}" Margin="0,32,0,10" Width="360">
            <ProgressBar.Foreground>
                <ImageBrush ImageSource="/Images/DownloadProgress2.png"/>
            </ProgressBar.Foreground>
            <ProgressBar.Background>
                <ImageBrush ImageSource="/Images/DownloadProgress1.png"/>
            </ProgressBar.Background>
        </ProgressBar>

        <TextBlock x:Name="PercentText"
                   Grid.Row="4"
                   Text=""
                   HorizontalAlignment="Right"
                   Foreground="Gray"
                   FontFamily="Tahoma"
                   FontSize="11"/>
    </Grid>
</Window>

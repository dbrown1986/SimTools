<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SimTools.KPSTConversionWindow"
        Title="Katy Perry Sweet Treats - Conversion in Progress"
        Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Background="#FF3E3E3E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Converting Katy Perry's Sweet Treats to Steam..." 
                       FontFamily="Tahoma" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       TextAlignment="Center" 
                       Margin="0,0,0,20"/>

            <ProgressBar Height="30" 
                         IsIndeterminate="True" 
                         Background="#FF2E2E2E" 
                         Foreground="#FFFFD200" 
                         Margin="0,0,0,20"/>

            <TextBlock x:Name="StatusText" 
                       Text="Initializing..." 
                       FontFamily="Tahoma" 
                       Foreground="#FFFFD200" 
                       TextAlignment="Center" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,20"/>

            <Button x:Name="CloseButton" 
                    Content="Close" 
                    Width="120" 
                    Height="35" 
                    HorizontalAlignment="Center" 
                    Click="CloseButton_Click" 
                    IsEnabled="False" 
                    FontFamily="Tahoma" 
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="SimTools.GenericKeys"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimTools"
        mc:Ignorable="d"
        Title="GenericKeys" Height="500" Width="400" WindowStyle="None"
        AllowsTransparency="True" HorizontalAlignment="Left" VerticalAlignment="Top"
        Foreground="{x:Null}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/Images/TS3_Box2.png"/>
    </Window.Background>
    <Grid>

        <!-- Close -->
        <Button x:Name="CloseButton" HorizontalAlignment="Left" Margin="344,451,0,0"
                VerticalAlignment="Top" Width="18" Height="30"
                Background="Black" BorderBrush="{x:Null}" Foreground="{x:Null}"
                Click="CloseButton_Click" Opacity="0"/>

        <!-- Game selector — context menu opened on left-click -->
        <Button x:Name="GenKeysButton" Content="Select Game ▸"
                HorizontalAlignment="Left" Margin="40,32,0,0" VerticalAlignment="Top"
                Width="162" Height="34" FontFamily="Tahoma" FontWeight="Bold"
                Click="GenKeysButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_yellow.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Info text -->
        <TextBlock x:Name="KeysInfoText"
                   HorizontalAlignment="Center" Margin="0,82,0,0"
                   TextWrapping="Wrap" VerticalAlignment="Top"
                   Width="352" Height="141"
                   Foreground="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"
                   FontFamily="Tahoma" FontWeight="Bold" TextAlignment="Center">
            <Run Text="Please select a game using the button above."/>
            <LineBreak/><Run/><LineBreak/>
            <Run Text="If a key is not working, or if an entire set of keys is not working. Please let me know in the Discord, so I can remedy it in the next version."/>
            <LineBreak/><Run/><LineBreak/>
            <Run Text="This feature, and all features related to it, may be removed in a future version of SimTools, at any time, at the behest of EA."/>
        </TextBlock>

        <!-- Read-only output field -->
        <TextBox x:Name="KeyField"
                 HorizontalAlignment="Center" Margin="0,250,0,0"
                 VerticalAlignment="Top" Width="252" Height="24"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 Text="Select a game and hit Generate…"
                 FontFamily="Consolas"/>

        <!-- Generate -->
        <Button x:Name="GenerateButton" Content="Generate"
                HorizontalAlignment="Left" Margin="75,283,0,0" VerticalAlignment="Top"
                Width="120" Height="34" FontFamily="Tahoma" FontWeight="Bold"
                Click="GenerateButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_yellow.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Copy -->
        <Button x:Name="CopyButton" Content="Copy"
                HorizontalAlignment="Left" Margin="205,283,0,0" VerticalAlignment="Top"
                Width="120" Height="34" FontFamily="Tahoma" FontWeight="Bold"
                Click="CopyButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_yellow.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <TextBlock x:Name="KeysInfoText_Copy"
            HorizontalAlignment="Center" Margin="0,332,0,0"
            TextWrapping="Wrap" VerticalAlignment="Top"
            Width="352" Height="32"
            FontFamily="Tahoma" FontWeight="Bold" TextAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}"><Run Text="These keys will not work for online registration."/><LineBreak/><Run Text="They will only allow for installation from retail discs."/></TextBlock>

    </Grid>
</Window>

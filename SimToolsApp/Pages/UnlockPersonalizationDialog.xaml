    <Window x:Class="SimTools.UnlockPersonalizationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimTools — Unlock Personalization"
        Height="200" Width="500"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Enter your donor key to personalise your copy of SimTools."
                   FontFamily="Tahoma" FontWeight="Bold" FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <!-- Key input -->
        <TextBox x:Name="KeyTextBox"
                 Grid.Row="1"
                 FontFamily="Consolas" FontSize="12"
                 Padding="5,4"
                 VerticalContentAlignment="Center"
                 KeyDown="KeyTextBox_KeyDown"/>

        <!-- Inline status message (hidden until needed) -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Text=""
                   FontFamily="Tahoma" FontSize="11"
                   Foreground="#CC0000"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="UnlockButton"
                    Content="Unlock"
                    Width="90" Height="28"
                    FontFamily="Tahoma" FontWeight="Bold"
                    Margin="0,0,8,0"
                    Click="UnlockButton_Click"/>
            <Button x:Name="ClearButton"
                    Content="Remove Key"
                    Width="90" Height="28"
                    FontFamily="Tahoma"
                    Margin="0,0,8,0"
                    Click="ClearButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="90" Height="28"
                    FontFamily="Tahoma"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

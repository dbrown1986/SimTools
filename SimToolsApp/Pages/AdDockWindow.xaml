<Window x:Class="SimTools.AdDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="560"
        Height="100"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!--
        MouseLeftButtonDown is handled in code-behind.
        Short press with no movement = click → open ad URL.
        Press + drag                 = move the dock window.
    -->
    <!--- <Border CornerRadius="6"
            
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#DD101018" Offset="0"/>
                <GradientStop Color="#EE0D0D14" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3"></DropShadowEffect>
            Color="Black" Opacity="0.65"/> 
        </Border.Effect> -->

    <Grid Background="Transparent" MouseLeftButtonDown="Dock_MouseLeftButtonDown">

        <Image x:Name="AdImage"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Visibility="Collapsed"/>

        <TextBlock x:Name="AdPlaceholder"
                   Text="Advertisement"
                   Foreground="#33FFFFFF"
                   FontSize="12"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</Window>

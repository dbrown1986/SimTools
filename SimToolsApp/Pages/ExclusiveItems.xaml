<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SimTools"
        xmlns:gif="http://wpfanimatedgif.codeplex.com" x:Class="SimTools.ExclusiveItems"
        mc:Ignorable="d"
        Title="SimTools — Exclusive Items"
        Height="640" Width="840"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Menu_Main.png"/>
        </Grid.Background>

        <Image x:Name="Clover" Visibility="Collapsed" HorizontalAlignment="Left" Height="100" VerticalAlignment="Top" Width="204" Source="/Images/Holidays/stpd.png" StretchDirection="UpOnly" Margin="-1,0,0,0"/>
        <Image x:Name="Clover2" Visibility="Collapsed" HorizontalAlignment="Left" Height="100" VerticalAlignment="Top" Width="204" Source="/Images/Holidays/stpd.png" StretchDirection="UpOnly" Margin="203,0,0,0"/>
        <Image x:Name="Clover3" Visibility="Collapsed" HorizontalAlignment="Left" Height="100" VerticalAlignment="Top" Width="204" Source="/Images/Holidays/stpd.png" StretchDirection="UpOnly" Margin="407,0,0,0"/>
        <Image x:Name="Clover4" Visibility="Collapsed" HorizontalAlignment="Left" Height="100" VerticalAlignment="Top" Width="204" Source="/Images/Holidays/stpd.png" StretchDirection="UpOnly" Margin="611,0,0,0"/>
        <Image x:Name="Clover5" Visibility="Collapsed" HorizontalAlignment="Left" Height="100" VerticalAlignment="Top" Width="204" Source="/Images/Holidays/stpd.png" StretchDirection="UpOnly" Margin="815,0,0,0"/>
        <Image gif:ImageBehavior.AnimatedSource="/Images/plumbob.gif" HorizontalAlignment="Left" Height="201" Margin="32,8,0,0" VerticalAlignment="Top" Width="113" Stretch="Fill"/>
        <Image x:Name="Fireworks" gif:ImageBehavior.AnimatedSource="/Images/Holidays/indpday_nye.gif" Visibility="Collapsed" HorizontalAlignment="Left" Height="201" Margin="10,8,0,0" VerticalAlignment="Top" Width="160" Stretch="Fill"/>
        <Image x:Name="SantaHat" Visibility="Collapsed" HorizontalAlignment="Left" Height="83" Margin="47,-11,0,0" VerticalAlignment="Top" Width="69" Source="/Images/Holidays/xmas.png"/>
        <Image x:Name="SimTools_Logo" HorizontalAlignment="Left" Height="194" Margin="8,8,0,0" VerticalAlignment="Top" Width="162" Source="/Images/SimTools_Logo.png" Stretch="Fill"/>

        <!-- Close button -->
        <Button x:Name="ExitApp" Content="" HorizontalAlignment="Left"
                Margin="801,8,0,0" VerticalAlignment="Top"
                Click="ExitApp_Click" Width="32" Height="32"
                BorderBrush="{x:Null}">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/close-button.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/close-hover.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Title -->
        <TextBlock x:Name="DonorItems" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="196,15,0,0"
                   Text="Donor / Patreon Exclusive Items"
                   Foreground="#FFD700"
                   FontFamily="Tahoma"
                   FontWeight="Bold"
                   FontSize="20" Height="26"/>

        <!-- Content area -->
        <ScrollViewer HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="196,58,0,0" Width="621" Height="78"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="ExclusiveItemsText"
                           TextWrapping="Wrap"
                           Foreground="#FF13FF00"
                           FontFamily="Tahoma"
                           FontSize="12"
                           Margin="0,0,0,12"
                           Text="Exclusive donor content will appear here. At the moment, there is no content available yet. I will however update this section as I make things."/>
                <TextBlock x:Name="ExclusiveItemsText2"
                    TextWrapping="Wrap"
                    Foreground="#FFFDFF00"
                    FontFamily="Tahoma"
                    FontSize="12"
                    Text="Users of SimTools who have donated can share these items with family and friends, but do not upload them to any modding sites."/>
            </StackPanel>
        </ScrollViewer>
        <Button x:Name="BackButton" Content="Back to Main Menu" HorizontalAlignment="Left" Margin="8,596,0,0" VerticalAlignment="Top" Width="159" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="BackButton_Click" FontSize="11" BorderBrush="{x:Null}">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_yellow.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <Image x:Name="SlimLivin" HorizontalAlignment="Left" Height="128" Margin="196,159,0,0" VerticalAlignment="Top" Width="128" Source="/Images/Exclusives/SlimLivin.jpg"/>
        <TextBlock x:Name="SlimLivinHeader" HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="336,160,0,0"
            Text="Slim Livin (Sims 3)"
            Foreground="#FFD700"
            FontFamily="Tahoma"
            FontWeight="Bold"
            FontSize="20" Height="26"/>
        <TextBlock HorizontalAlignment="Left" Margin="336,192,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontFamily="Tahoma" Foreground="#FF13FF00" Height="40" Width="481" FontWeight="Bold"><Run FontFamily="Courier New" FontSize="11.333333333333332" Text="A quaint, but luxurious abode. Small and compact at 10x10. A generous starter for any sim with 2 bedrooms and 1 bathroom. Base game items only."/></TextBlock>
        <Button x:Name="SlimLivinDownloadButton" Content="Download Now" HorizontalAlignment="Left" Margin="336,253,0,0" VerticalAlignment="Top" Width="162" Height="34" FontFamily="Tahoma" FontWeight="Bold" Click="SlimLivinDownloadButton_Click" BorderBrush="{x:Null}">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Images/button_normal.png"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="/Images/button_yellow.png"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
